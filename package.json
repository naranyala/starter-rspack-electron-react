{
  "name": "electron-react-rsbuild",
  "version": "0.1.2",
  "description": "Boilerplate using Rsbuild as bundler for Electron apps.",
  "main": "main.cjs",
  "scripts": {
    "dev": "bun run scripts/dev-runner.js",
    "build": "bun run scripts/build.js",
    "start": "bunx electron .",
    "dist": "bun run scripts/package.js"
  },
  "author": "naranyala",
  "build": {
    "appId": "com.some.electron.quickstart",
    "dmg": {
      "contents": [
        {
          "x": 110,
          "y": 150
        },
        {
          "x": 240,
          "y": 150,
          "type": "link",
          "path": "/Applications"
        }
      ]
    },
    "linux": {
      "category": "Utility",
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "dist/icon.ico"
    },
    "win": {
      "target": "msi",
      "icon": "dist/icon.ico"
    },
    "files": [
      "main.cjs",
      "dist/**/*"
    ]
  },
  "keywords": [
    "rsbuild",
    "react",
    "electron"
  ],
  "license": "MIT",
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "get-port": "^7.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "styled-components": "^6.3.8",
    "winbox": "^0.2.82"
  },
  "devDependencies": {
    "@rspack/cli": "^1.7.4",
    "@rspack/core": "^1.7.4",
    "@rspack/plugin-html": "^0.5.8",
    "@types/minimatch": "^6.0.0",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@types/react-dom": "^19.2.3",
    "css-loader": "^7.1.3",
    "electron": "^40.1.0",
    "electron-builder": "^26.4.0",
    "electron-is-dev": "^3.0.1",
    "electron-reload": "^1.5.0",
    "fs-extra": "^11.3.3",
    "html-webpack-plugin": "^5.6.6",
    "mini-css-extract-plugin": "^2.10.0",
    "style-loader": "^4.0.0",
    "typescript": "^5.9.3",
    "wait-on": "^9.0.3"
  }
}
